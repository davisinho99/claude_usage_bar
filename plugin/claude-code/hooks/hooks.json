{
  "description": "Usage bar — monitors context consumption and displays a live progress bar in Claude Code's statusLine",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh",
            "timeout": 10,
            "statusMessage": "Starting usage bar monitor..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/stop.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
